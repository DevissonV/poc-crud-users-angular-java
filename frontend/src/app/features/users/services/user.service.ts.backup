import { Injectable, signal, computed, inject } from '@angular/core';
import { User, CreateUserDto, UpdateUserDto } from '../../../core/models/user.model';
import { UserHttpService } from '../../../core/services/user-http.service';

/**
 * Servicio principal para gestión de usuarios.
 * 
 * Este servicio proporciona la lógica de negocio para el CRUD de usuarios
 * utilizando Signals de Angular para reactividad automática y conectando
 * con el backend REST API.
 * 
 * @class UserService
 * @injectable
 * @description
 * Capa de lógica de negocio que orquesta las operaciones CRUD,
 * maneja el estado reactivo con Signals, y se comunica con el
 * backend a través del servicio HTTP.
 * 
 * @example
 * ```typescript
 * constructor(private userService: UserService) {
 *   effect(() => {
 *     console.log('Usuarios actuales:', this.userService.users());
 *   });
 * }
 * ```
 */
@Injectable({
  providedIn: 'root'
})
export class UserService {
  /**
   * Servicio HTTP para llamadas al backend.
   * @private
   * @readonly
   */
  private readonly httpService = inject(UserHttpService);

  /**
   * Signal privado que contiene el array de usuarios.
   * @private
   */
  private readonly usersSignal = signal<User[]>([]);

  /**
   * Signal público de solo lectura con todos los usuarios.
   * Se actualiza automáticamente cuando cambia usersSignal.
   * 
   * @readonly
   * @returns {Signal<User[]>} Signal con el array de usuarios.
   * 
   * @example
   * ```typescript
   * // En un componente
   * users = this.userService.users;
   * 
   * // En el template
   * @for (user of users(); track user.id) {
   *   <div>{{ user.nombre }}</div>
   * }
   * ```
   */
  readonly users = this.usersSignal.asReadonly();

  /**
   * Signal computado que indica si hay usuarios.
   * 
   * @readonly
   * @returns {Signal<boolean>} true si hay al menos un usuario.
   * 
   * @example
   * ```typescript
   * @if (hasUsers()) {
   *   <p>Hay usuarios disponibles</p>
   * } @else {
   *   <p>No hay usuarios</p>
   * }
   * ```
   */
  readonly hasUsers = computed(() => this.usersSignal().length > 0);

  /**
   * Signal computado con el total de usuarios.
   * 
   * @readonly
   * @returns {Signal<number>} Cantidad total de usuarios.
   * 
   * @example
   * ```typescript
   * <p>Total de usuarios: {{ userCount() }}</p>
   * ```
   */
  readonly userCount = computed(() => this.usersSignal().length);

  /**
   * Signal que indica si hay una operación en curso.
   * 
   * @readonly
   * @returns {Signal<boolean>} true si hay una operación en curso.
   */
  private readonly loadingSignal = signal<boolean>(false);
  readonly loading = this.loadingSignal.asReadonly();

  /**
   * Signal que contiene el último error ocurrido.
   * 
   * @readonly
   * @returns {Signal<string | null>} Mensaje de error o null.
   */
  private readonly errorSignal = signal<string | null>(null);
  readonly error = this.errorSignal.asReadonly();

  constructor() {
    // Cargar usuarios desde el backend al inicializar
    this.loadUsers();
  }

  /**
   * Carga todos los usuarios desde el backend.
   * 
   * @returns {void}
   * 
   * @example
   * ```typescript
   * this.userService.loadUsers();
   * ```
   */
  loadUsers(): void {
    this.loadingSignal.set(true);
    this.errorSignal.set(null);

    this.httpService.getAllUsers().subscribe({
      next: (users) => {
        this.usersSignal.set(user desde el backend.
   * 
   * @param {string} id - ID del usuario a buscar.
   * @param {Function} callback - Función callback que recibe el usuario o error.
   * 
   * @example
   * ```typescript
   * this.userService.getUserById('abc123', (user, error) => {
   *   if (user) {
   *     console.log(`Usuario: ${user.nombre} ${user.apellido}`);
   *   }
   * });
   * ```
   */
  getUserById(id: string, callback: (user: User | null, error: string | null) => void): void {
    this.loadingSignal.set(true);
    this.errorSignal.set(null);

    this.httpService.getUserById(id).subscribe({
      next: (user) => {
        this.loadingSignal.set(false);
        callback(user, null);
      },
      error: (error) => {
        this.errorSignal.set(error.message);
        this.loadingSignal.set(false);
        callback(null, error.message);
      }
    });
  }
 en el backend.
   * 
   * @param {CreateUserDto} userData - Datos del usuario a crear.
   * @param {Function} callback - Función callback que recibe el usuario creado o error.
   * 
   * @example
   * ```typescript
   * this.userService.createUser({
   *   nombre: 'Juan',
   *   apellido: 'Pérez',
   *   email: 'juan@example.com',
   *   telefono: '+57 300 123 4567',
   *   fechaNacimiento: new Date('1990-01-01')
   * }, (user, error) => {
   *   if (user) {
   *     console.log(`Usuario creado con ID: ${user.id}`);
   *   }
   * });
   * ```
   */
  createUser(userData: CreateUserDto, callback: (user: User | null, error: string | null) => void): void {
    this.loadingSignal.set(true);
    this.errorSignal.set(null);

    this.httpService.createUser(userData).subscribe({
      next: (user) => {
        // Actualizar signal local
        this.usersSignal.update(users => [...users, user]);
        this.loadingSignal.set(false);
        callback(user, null);
      },
      error: (error) => {
        this.errorSignal.set(error.message);
        this.loadingSignal.set(false);
        callback(null, error.message);
      }
    })Usuario creado con ID: ${newUser.id}`);
   * ```
   */
  createUser(userData: CreateUserDto): User {
    // Validar email único
    if (this.storageService.emailExists(userData.email)) {
      throw new Error('El email ya está registrado en el sistema');
    }

    // Validar campos requeridos
    this.validateUserData(userData);

    // Crear usuario con ID generado
    const newUser: User = {
      ...userData,
      id: this.generateId()
    };

    // Guardar en localStorage
    this.storageService.save(newUser);

    // Actualizar signal
    this.usersSignal.update(users => [...users, newUser]);

    return newUser;
  }

  /**
   * Actualiza un usuario existente en el backend.
   * 
   * @param {User} userData - Datos completos del usuario a actualizar (debe incluir id).
   * @param {Function} callback - Función callback que recibe el usuario actualizado o error.
   * 
   * @example
   * ```typescript
   * this.userService.updateUser({
   *   id: 'abc123',
   *   nombre: 'Juan Carlos',
   *   apellido: 'Pérez',
   *   email: 'nuevo@example.com',
   *   telefono: '+57 310 456 7890',
   *   fechaNacimiento: new Date('1990-01-01')
   * }, (user, error) => {
   *   if (user) {
   *     console.log('Usuario actualizado');
   *   }
   * });
   * ```
   */
  updateUser(userData: User, callback: (user: User | null, error: string | null) => void): void {
    this.loadingSignal.set(true);
    this.errorSignal.set(null);

    this.httpService.updateUser(userData).subscribe({
      next: (user) => {
        // Actualizar signal local
        this.usersSignal.update(users =>
          users.map(u => u.id === user.id ? user : u)
        );
        this.loadingSignal.set(false);
        callback(user, null);
      },
      error: (error) => {
        this.errorSignal.set(error.message);
        this.loadingSignal.set(false);
        callback(null, error.message);
      }
    });
  }

  /**
   * Elimina un usuario por su ID en el backend.
   * 
   * @param {string} id - ID del usuario a eliminar.
   * @param {Function} callback - Función callback que recibe el resultado o error.
   * 
   * @example
   * ```typescript
   * this.userService.deleteUser('abc123', (success, error) => {
   *   if (success) {
   *     console.log('Usuario eliminado exitosamente');
   *   }
   * });
   * ```
   */
  deleteUser(id: string, callback: (success: boolean, error: string | null) => void): void {
    this.loadingSignal.set(true);
    this.errorSignal.set(null);

    this.httpService.deleteUser(id).subscribe({
      next: () => {
        // Actualizar signal local
        this.usersSignal.update(users =>
          users.filter(user => user.id !== id)
        );
        this.loadingSignal.set(false);
        callback(true, null);
      },
      error: (error) => {
        this.errorSignal.set(error.message);
        this.loadingSignal.set(false);
        callback(false, error.message);
      }
    });
  }

  /**
   * Busca usuarios por nombre, apellido o email en el backend.
   * 
   * @param {string} searchTerm - Término de búsqueda.
   * @param {Function} callback - Función callback que recibe los resultados o error.
   * 
   * @example
   * ```typescript
   * this.userService.searchUsers('juan', (results, error) => {
   *   if (results) {
   *     console.log(`Encontrados ${results.length} usuarios`);
   *   }
   * });
   * ```
   */
  searchUsers(searchTerm: string, callback: (users: User[] | null, error: string | null) => void): void {
    if (!searchTerm || searchTerm.trim() === '') {
      callback(this.usersSignal(), null);
      return;
    }

    this.loadingSignal.set(true);
    this.errorSignal.set(null);

    this.httpService.searchUsers(searchTerm).subscribe({
      next: (users) => {
        this.loadingSignal.set(false);
        callback(users, null);
      },
      error: (error) => {
        this.errorSignal.set(error.message);
        this.loadingSignal.set(false);
        callback(null, error.message);
      }
    });
  }

  /**
   * Busca usuarios localmente (en el signal) sin llamada al backend.
   * 
   * @param {string} searchTerm - Término de búsqueda.
   * @returns {User[]} Array de usuarios que coinciden con la búsqueda.
   */
  searchUsersLocal(searchTerm: string): User[] {
    if (!searchTerm || searchTerm.trim() === '') {
      return this.usersSignal();
    }

    const term = searchTerm.toLowerCase().trim();
    return this.usersSignal().filter(user =>
      user.nombre.toLowerCase().includes(term) ||
      user.apellido.toLowerCase().includes(term) ||
      user.email.toLowerCase().includes(term)
    );
  }
}
